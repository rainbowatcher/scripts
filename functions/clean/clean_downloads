local downloads="$HOME/Downloads"

move_by_suffix() {
    local target_dir=$1
    shift

    local file
    local suffix
    local lowered_name
    local matched

    for file in "$downloads"/*(N.); do
        lowered_name=${file:t:l}
        matched=0

        for suffix in "$@"; do
            if [[ ${lowered_name} == *${suffix:l} ]]; then
                matched=1
                break
            fi
        done

        if [[ ${matched} -eq 0 ]]; then
            continue
        fi

        mkdir -p "${target_dir}"
        if [[ -e "${target_dir}/${file:t}" ]]; then
            warn "target file exists: ${target_dir}/${file:t}"
            continue
        fi

        mv "${file}" "${target_dir}/${file:t}"
    done
}

step "handle documents"
local doc_suffixes=(.doc .docx .xlsx .pdf .md .html)
move_by_suffix "$downloads/document" "${doc_suffixes[@]}"

# image
step "handle images"
local img_suffixes=(.jpg .png .drawio .vsdx .gif .jpeg .svg .webp)
move_by_suffix "$downloads/image" "${img_suffixes[@]}"

step "handle packages"
local pkg_suffixes=(.pkg .dmg .exe .msi)
move_by_suffix "$downloads/package" "${pkg_suffixes[@]}"

step "handle compress file"
local compress_suffixes=(.zip .gz .gz2 .rar .7z .tar.xz)
move_by_suffix "$downloads/compress" "${compress_suffixes[@]}"

step "handle jars"
move_by_suffix "$downloads/jars" .jar

step "handle system mirror"
local mirror_suffixes=(.iso)
move_by_suffix "$downloads/mirrors" "${mirror_suffixes[@]}"

step "handle scripts"
local script_suffixes=(.sh .bat .zsh .js .ts .jsx .zx .ktr .sql .py)
move_by_suffix "$downloads/scripts" "${script_suffixes[@]}"

step "handle chrome extensions"
move_by_suffix "$downloads/chromeExtensions" .crx

step "handle data files"
local data_suffixes=(.csv .json .xml .txt .dat)
move_by_suffix "$downloads/data" "${data_suffixes[@]}"

step "handle configs"
local config_suffixes=(.terminal)
move_by_suffix "$downloads/config" "${config_suffixes[@]}"

step "handle videos"
local video_suffixes=(.mp4 .avi .rmvb)
move_by_suffix "$downloads/video" "${video_suffixes[@]}"

step "handle fonts"
local font_suffixes=(.ttf .otf .woff .woff2)
move_by_suffix "$downloads/fonts" "${font_suffixes[@]}"

step_end 'clear up Downloads'
