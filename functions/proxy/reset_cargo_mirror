local __CARGO_CONFIG_FILE=${__CARGO_CONFIG_FILE:-"$HOME/.cargo/config.toml"}
if [[ -f "${__CARGO_CONFIG_FILE}" ]] && [[ $(grep -c "registry" "${__CARGO_CONFIG_FILE}") -eq 1 ]]; then
    sed -ie '/^$/d' "${__CARGO_CONFIG_FILE}"
    sed -ie '/^\[source/d' "${__CARGO_CONFIG_FILE}"
    sed -ie '/mirror/d' "${__CARGO_CONFIG_FILE}"
    judge "unset cargo mirror"
else
    info "cargo mirror has already unset"
fi
