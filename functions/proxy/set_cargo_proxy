local __CARGO_CONFIG_FILE=${__CARGO_CONFIG_FILE:-"$HOME/.cargo/config.toml"}
local __CARGO_CONFIG_DIR=${__CARGO_CONFIG_FILE:h}
local __CARGO_PROXY_BLOCK_START="# >>> scripts cargo proxy >>>"
local __CARGO_PROXY_BLOCK_END="# <<< scripts cargo proxy <<<"
local __CARGO_TMP_FILE

if [[ -z ${HTTP_PROXY_ADDR:-} ]]; then
    error "HTTP_PROXY_ADDR is not set"
    return 1
fi

mkdir -p "${__CARGO_CONFIG_DIR}"
touch "${__CARGO_CONFIG_FILE}"

if grep -Fqx 'proxy = "'"${HTTP_PROXY_ADDR}"'"' "${__CARGO_CONFIG_FILE}"; then
    info "cargo proxy has already set"
    return 0
fi

__CARGO_TMP_FILE=$(mktemp)
awk \
    -v start="${__CARGO_PROXY_BLOCK_START}" \
    -v end="${__CARGO_PROXY_BLOCK_END}" \
    -v proxy="${HTTP_PROXY_ADDR}" \
    '
BEGIN {
    skip = 0
}
$0 == start {
    skip = 1
    next
}
$0 == end {
    skip = 0
    next
}
skip == 0 {
    print
}
END {
    if (NR > 0) {
        print ""
    }
    print start
    print "[http]"
    print "proxy = \"" proxy "\""
    print end
}
' "${__CARGO_CONFIG_FILE}" >"${__CARGO_TMP_FILE}"

mv "${__CARGO_TMP_FILE}" "${__CARGO_CONFIG_FILE}"
judge "set cargo proxy to \"${HTTP_PROXY_ADDR}\""
